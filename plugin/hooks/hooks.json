{
  "description": "Claude-recall memory system hooks (direct SQLite, no worker daemon)",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/scripts/bun-runner.sh\" \"${CLAUDE_PLUGIN_ROOT}/scripts/hook-command.js\" claude-code context",
            "timeout": 10
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/scripts/bun-runner.sh\" \"${CLAUDE_PLUGIN_ROOT}/scripts/hook-command.js\" claude-code session-init",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/scripts/bun-runner.sh\" \"${CLAUDE_PLUGIN_ROOT}/scripts/hook-command.js\" claude-code observation",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/scripts/bun-runner.sh\" \"${CLAUDE_PLUGIN_ROOT}/scripts/hook-command.js\" claude-code summarize",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/scripts/bun-runner.sh\" \"${CLAUDE_PLUGIN_ROOT}/scripts/hook-command.js\" claude-code session-end",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
